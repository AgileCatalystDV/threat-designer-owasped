# Lokale Docker-stack — kopieer naar `.env.local` en pas aan.
# (`docker-compose.local.yml` gebruikt `env_file: .env.local` voor app, threat-designer, sentry)
#
#   cp .env.local.example .env.local
#
# `.env.local` staat in .gitignore — geen secrets committen.

# ── LLM (Ollama op de host; containers via host.docker.internal) ─────────────
MODEL_PROVIDER=ollama
LOCAL_MODEL=qwen3:32b
INFERENCE_BASE_URL=http://host.docker.internal:11434/v1
INFERENCE_API_KEY=ollama

# Optioneel — andere providers / tuning (zie backend/threat_designer/constants.py)
# OPENAI_API_KEY=
# LOG_LEVEL=INFO
