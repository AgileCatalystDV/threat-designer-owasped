# Lokale Docker-stack — kopieer naar `.env.local` en pas aan.
# (`docker-compose.local.yml` gebruikt `env_file: .env.local` voor app, threat-designer, sentry)
#
#   cp .env.local.example .env.local
#
# `.env.local` staat in .gitignore — geen secrets committen.

# ── LLM — OpenAI-compatibele API (`MODEL_PROVIDER=ollama` = ChatOpenAI + base_url)
# Base-URL moet eindigen op `/v1` (niet `/v1/models` — dat is alleen de model-lijst).

# Optie A — Ollama op dezelfde machine als Docker Desktop:
MODEL_PROVIDER=ollama
LOCAL_MODEL=qwen3:32b
INFERENCE_BASE_URL=http://host.docker.internal:11434/v1
INFERENCE_API_KEY=ollama

# Optie B — LM Studio op het LAN (voorlopige keuze team: Qwen 3.5 27B):
# Model-id exact uit `GET …/v1/models` — voorbeeld team: qwen3.5-27b
# MODEL_PROVIDER=ollama
# LOCAL_MODEL=qwen3.5-27b
# INFERENCE_BASE_URL=http://192.168.68.101:1234/v1
# INFERENCE_API_KEY=lm-studio

# Optioneel — andere providers / tuning (zie backend/threat_designer/constants.py)
# OPENAI_API_KEY=
# LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG          # voor llm_raw_response (tool_calls + content preview) in td-agent logs
# LLM_DEBUG_RESPONSE_MAX_CHARS=4000
#
# Threat agent — stop oneindige loop bij herhaalde add_threats-schemafout (ToolNode / LM Studio)
# THREAT_AGENT_MAX_ADD_THREATS_SCHEMA_ERRORS=3
#
# ── Frontend (Vite) — niet via dit bestand naar containers; wel voor `npm run dev` ──
# Kopieer naar `.env.development` of `.env.local` (projectroot, gitignored) indien je Sentry wilt:
#   VITE_SENTRY_ENABLED=true
#   VITE_SENTRY_BASE_URL=http://localhost:8090
# Stack moet Sentry draaien: npm run stack:up:full  (profiel full). Zie quick-start-guide/local-stack-owasped.md §4.3.
